<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/axisTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        app:tabTextColor="#AAAAAA"
        app:tabSelectedTextColor="#FF5C8D"
        app:tabIndicatorColor="#FF5C8D">
        <com.google.android.material.tabs.TabItem android:text="ROLL" />
        <com.google.android.material.tabs.TabItem android:text="PITCH" />
        <com.google.android.material.tabs.TabItem android:text="YAW" />
        <com.google.android.material.tabs.TabItem android:text="THR" />
    </com.google.android.material.tabs.TabLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="24dp"
        android:baselineAligned="false">

        <!-- Left Column (40%): Controls -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Weight -->
                <TextView
                    android:id="@+id/tvWeightLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Weight: 100%"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:paddingBottom="8dp"/>

                <SeekBar
                    android:id="@+id/sbWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="#FF5C8D"
                    android:thumbTint="#FF5C8D" />

                <!-- Offset -->
                <TextView
                    android:id="@+id/tvOffsetLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Offset: 0%"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="24dp"
                    android:paddingBottom="8dp"/>

                <SeekBar
                    android:id="@+id/sbOffset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="100"
                    android:progressTint="#FF5C8D"
                    android:thumbTint="#FF5C8D" />

                <!-- Expo -->
                <TextView
                    android:id="@+id/tvExpoLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Expo: 0%"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="24dp"
                    android:paddingBottom="8dp"/>

                <SeekBar
                    android:id="@+id/sbExpo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="100"
                    android:progressTint="#FF5C8D"
                    android:thumbTint="#FF5C8D" />
            </LinearLayout>
        </ScrollView>

        <!-- Right Column (60%): Graph -->
        <com.goldarte.mavlinkjoystick.views.CurveGraphView
            android:id="@+id/curveGraphView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.6"
            android:layout_marginStart="24dp"
            android:background="#121212" />

    </LinearLayout>
</LinearLayout>
