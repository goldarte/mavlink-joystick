<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:baselineAligned="false">

        <!-- Left Column: Boundaries -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Boundaries Visibility"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingBottom="16dp"/>

            <CheckBox
                android:id="@+id/cbShowCircularArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show Circular Area"
                android:textColor="#FFFFFF"
                android:buttonTint="#FF5C8D"
                android:fontFamily="monospace"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/cbShowSquareArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show Square Boundaries"
                android:textColor="#FFFFFF"
                android:buttonTint="#FF5C8D"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <CheckBox
                android:id="@+id/cbShowCircleBoundaries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show Circle Boundaries"
                android:textColor="#FFFFFF"
                android:buttonTint="#FF5C8D"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="24dp"
            android:layout_height="match_parent" />

        <!-- Right Column: Knobs Color -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Knobs Color"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingBottom="16dp"/>

            <GridLayout
                android:id="@+id/colorPickerContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">
                <!-- Color views will be added programmatically -->
            </GridLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
