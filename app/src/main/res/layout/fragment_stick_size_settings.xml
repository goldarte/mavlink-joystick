<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Joystick Size / Sensitivity"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingBottom="16dp"/>

        <TextView
            android:id="@+id/tvLeftStickSizeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Left Stick: 100%"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:paddingBottom="8dp"/>

        <SeekBar
            android:id="@+id/sbLeftStickSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="50"
            android:progress="50"
            android:progressTint="#FF5C8D"
            android:thumbTint="#FF5C8D" />

        <TextView
            android:id="@+id/tvRightStickSizeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Right Stick: 100%"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <SeekBar
            android:id="@+id/sbRightStickSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="50"
            android:progress="50"
            android:progressTint="#FF5C8D"
            android:thumbTint="#FF5C8D" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adjust the physical area used by each joystick independently. Lower values make the sticks smaller and more sensitive."
            android:textColor="#666666"
            android:textSize="11sp"
            android:paddingTop="24dp"
            android:lineSpacingExtra="3dp"/>

    </LinearLayout>
</ScrollView>
